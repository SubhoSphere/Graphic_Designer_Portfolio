# ==========================================
# API KEYS
# ==========================================

# Resend API Key for sending emails from the Contact Form
# Get yours at https://resend.com
RESEND_API_KEY=re_your_api_key_here

# ==========================================
# PUBLIC CONTACT INFORMATION
# ==========================================
# These variables can be prefixed with NEXT_PUBLIC_ if you want to use them directly in the frontend

# Primary Contact Emails
NEXT_PUBLIC_CONTACT_EMAIL=contact@reshabcreative.com
NEXT_PUBLIC_SUPPORT_EMAIL=reshab@info.com

# Phone Numbers
NEXT_PUBLIC_PHONE_NUMBER="+1 (800) 234 - 5678"
NEXT_PUBLIC_WHATSAPP_NUMBER="+1 (555) 123-4567"

# Location & Office
NEXT_PUBLIC_OFFICE_ADDRESS="123 Creative Ave, USA"
NEXT_PUBLIC_BUSINESS_HOURS="9:00 AM - 6:00 PM"

# ==========================================
# SOCIAL MEDIA LINKS (Optional)
# ==========================================
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/reshab
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/reshab
NEXT_PUBLIC_BEHANCE_URL=https://behance.net/reshab
NEXT_PUBLIC_DRIBBBLE_URL=https://dribbble.com/reshab
NEXT_PUBLIC_GITHUB_URL=https://github.com/reshab
